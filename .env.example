# Local development template — copy to .env and adjust.
# .env is gitignored; .env.production is committed (public client-side config only).
# All VITE_* vars are baked into the client bundle at build time — never put secrets here.

# --- Auth (Cognito Hosted UI via the auth.safepass.com bridge) ---
# Always use the bridge domain, never the raw *.amazoncognito.com endpoint.
COGNITO_KIOSK_AUDIENCE=469o45rb474u57fba3ecnd0lkv
VITE_COGNITO_DOMAIN=https://auth.safepass.com
VITE_COGNITO_CLIENT_ID=469o45rb474u57fba3ecnd0lkv
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_COGNITO_LOGOUT_URI=http://localhost:5173/auth/logout
# Native deep-link callbacks (used when running in the Capacitor shell):
# VITE_COGNITO_NATIVE_REDIRECT_URI=safepasskiosk://localhost/auth/callback
# VITE_COGNITO_NATIVE_LOGOUT_URI=safepasskiosk://localhost/auth/logout

# --- API ---
VITE_KIOSK_API_BASE=https://api.safepass.com

# --- Dev conveniences ---
# VITE_MODE=dev enables the auth bypass in AuthContext (pair with VITE_DEV_KIOSK_JWT if needed).
VITE_MODE=dev
# Mock API mode (createMockKioskApi) — works with no backend at all.
VITE_KIOSK_MOCK=true
# VITE_DEV_KIOSK_JWT=

# --- Kiosk behavior ---
VITE_KIOSK_IDLE_MINUTES=5
# VITE_NETWORK_AWARE_RECOVERY=true
# Append raw backend error codes to user-facing messages (debug aid):
# VITE_SHOW_ERROR_CODES=true

# --- Production-only flags (set in .env.production / Cloudflare build env) ---
# VITE_BLOCK_BROWSER_ACCESS=true   # browser gate in src/main.jsx; native shell bypasses via isNative
