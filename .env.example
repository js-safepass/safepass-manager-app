# Local development template — copy to .env and adjust.
# .env is gitignored; .env.production is committed (public client-side config only).
# All VITE_* vars are baked into the client bundle at build time — never put secrets here.

# --- Auth (Cognito Hosted UI via the auth.safepass.com bridge) ---
# Always use the bridge domain, never the raw *.amazoncognito.com endpoint.
VITE_COGNITO_DOMAIN=https://auth.safepass.com
# This app's dedicated Cognito app client (pool us-gov-west-1_jpRl7DoR5),
# provisioned 2026-07-10.
VITE_COGNITO_CLIENT_ID=5grgviekbiv44ab9llnsdqnp55
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_COGNITO_LOGOUT_URI=http://localhost:5173/auth/logout
# Native deep-link callbacks (used when running in the Capacitor shell):
# VITE_COGNITO_NATIVE_REDIRECT_URI=safepassmanager://localhost/auth/callback
# VITE_COGNITO_NATIVE_LOGOUT_URI=safepassmanager://localhost/auth/logout

# --- API ---
VITE_MANAGER_API_BASE=https://api.safepass.com

# --- Dev conveniences ---
# VITE_MODE=dev enables the auth bypass in AuthContext (pair with VITE_DEV_MANAGER_JWT if needed).
VITE_MODE=dev
# Mock API mode (createMockManagerApi) — the whole app works with no backend at all.
VITE_MANAGER_MOCK=true
# VITE_DEV_MANAGER_JWT=

# --- Debug aids ---
# Append raw backend error codes to user-facing messages:
# VITE_SHOW_ERROR_CODES=true
