# Android release signing — copy this file to android/keystore.properties
# (git-ignored) and fill in real values, OR set the ANDROID_KEYSTORE_* env vars
# in CI. NEVER commit the real keystore.properties or the .jks/.keystore file.
#
# Generate an upload keystore once per app:
#   keytool -genkeypair -v -keystore upload-keystore.jks -alias upload \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile may be absolute or relative to the android/ directory.
storeFile=/absolute/path/to/upload-keystore.jks
storePassword=CHANGEME
keyAlias=upload
keyPassword=CHANGEME
