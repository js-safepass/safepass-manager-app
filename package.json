{
  "name": "safepass-manager-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:staging": "CLOUDFLARE_ENV=staging vite build --mode staging",
    "cap:build": "CAP_BUILD=true vite build",
    "cap:build:staging": "CAP_BUILD=true vite build --mode staging",
    "cap:sync": "npm run cap:build && npx cap sync",
    "cap:sync:staging": "npm run cap:build:staging && npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:ios": "npm run cap:build && npx cap sync ios && npx cap run ios",
    "cap:run:android": "npm run cap:build && npx cap sync android && npx cap run android",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/core": "^8.4.2",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.4.2",
    "@fontsource/dm-sans": "^5.2.8",
    "@fortawesome/fontawesome-free": "^7.3.0",
    "prop-types": "^15.8.1",
    "react": "^19.0.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@cloudflare/vite-plugin": "^1.0.0",
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "sass": "^1.101.0",
    "typescript": "^5.5.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
