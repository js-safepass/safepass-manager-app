# Local development template — copy to .env and adjust.
# .env is gitignored; .env.production is committed (public client-side config only).
# All VITE_* vars are baked into the client bundle at build time — never put secrets here.

# --- Auth (Cognito Hosted UI via the auth.safepass.com bridge) ---
# Always use the bridge domain, never the raw *.amazoncognito.com endpoint.
VITE_COGNITO_DOMAIN=https://auth.safepass.com
# This app's dedicated Cognito app client (pool us-gov-west-1_jpRl7DoR5),
# provisioned 2026-07-10.
VITE_COGNITO_CLIENT_ID=5grgviekbiv44ab9llnsdqnp55
VITE_COGNITO_REDIRECT_URI=http://localhost:5273/auth/callback
VITE_COGNITO_LOGOUT_URI=http://localhost:5273/auth/logout
# Native deep-link callbacks (used when running in the Capacitor shell):
# VITE_COGNITO_NATIVE_REDIRECT_URI=safepassmanager://localhost/auth/callback
# VITE_COGNITO_NATIVE_LOGOUT_URI=safepassmanager://localhost/auth/logout

# --- API ---
VITE_MANAGER_API_BASE=https://api.safepass.com

# --- Mode matrix (both are build vars, baked at build/dev-server start) ---
#   VITE_MODE=dev  + VITE_MANAGER_MOCK=true   → full mock: no Cognito, no backend
#   VITE_MODE=     + VITE_MANAGER_MOCK=true   → real sign-in, mock data (auth flow testing)
#   VITE_MODE=     + VITE_MANAGER_MOCK=false  → real sign-in, live API (staging/production posture)
# VITE_MODE=dev enables the auth bypass in AuthContext (pair with VITE_DEV_MANAGER_JWT if needed).
VITE_MODE=dev
# Mock API mode (createMockManagerApi) — the whole app works with no backend at all.
VITE_MANAGER_MOCK=true
# VITE_DEV_MANAGER_JWT=

# --- Network-aware recovery (NetworkContext.jsx) ---
# Explicit opt-in kill switch, default OFF. When 'true': background
# connectivity probing + the offline chip render. When unset: no probe
# traffic and `online` is forced true. Set per environment (.env.staging /
# .env.production or the Cloudflare build env).
# VITE_NETWORK_AWARE_RECOVERY=true

# --- Debug aids ---
# Append raw backend error codes to user-facing messages:
# VITE_SHOW_ERROR_CODES=true

# --- Local dev against the STAGING pool + API (real auth, real staging data) ---
# Uncomment these four (and set VITE_MODE= empty, VITE_MANAGER_MOCK=false):
# VITE_COGNITO_DOMAIN=https://safepass-staging.auth-fips.us-gov-west-1.amazoncognito.com
# VITE_COGNITO_CLIENT_ID=4diu3cb4nnt78al45dv5r8iqu9
# VITE_MANAGER_API_BASE=https://safepass-api.forgearray.dev
# (localhost:5273 callbacks are registered on the staging client)
